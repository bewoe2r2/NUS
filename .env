# Bewo Healthcare Companion - Environment Configuration
# IMPORTANT: Never commit real secrets. Copy this to .env.local for development.

# --- Required ---
GEMINI_API_KEY=

# --- SEA-LION (AI Singapore Official API) ---
SEALION_API_KEY=

# --- SEA-LION (Cloudflare Workers AI - fallback) ---
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_AUTH_TOKEN=

# --- Security ---
# BEWO_API_KEY must be set to a strong, unique value in production.
# The application will refuse to start if this is left as the default.
BEWO_API_KEY=
CORS_ORIGINS=http://localhost:3000

# --- Tool Providers ---
APPOINTMENT_PROVIDER=mock
ALERT_PROVIDER=mock

# --- Optional ---
DEBUG_MODE=False
LOG_LEVEL=WARNING
API_HOST=0.0.0.0
API_PORT=8000
