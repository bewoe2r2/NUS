# Bewo Healthcare Companion - Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env with real secrets to version control.

# --- Required ---
# Google Gemini API Key (get from https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_api_key_here

# --- SEA-LION (AI Singapore Official API) ---
# Sign up at https://playground.sea-lion.ai/
SEALION_API_KEY=your_sealion_api_key

# --- SEA-LION (Cloudflare Workers AI - fallback) ---
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_AUTH_TOKEN=

# --- Security ---
# BEWO_API_KEY must be a strong, unique value. App refuses to start without it
# in production (when DEBUG_MODE=False).
BEWO_API_KEY=generate-a-strong-random-key-here

# Allowed CORS origins (comma-separated, restrict in production)
CORS_ORIGINS=http://localhost:3000

# --- Tool Providers (optional — uses mock providers by default) ---
# Appointment Booking: "mock" (demo) or "healthhub" (production FHIR R4)
APPOINTMENT_PROVIDER=mock
HEALTHHUB_API_URL=https://api.healthhub.sg/v1
HEALTHHUB_API_KEY=

# Caregiver Alerts: "mock" (demo) or "twilio" (production SMS/Voice)
ALERT_PROVIDER=mock
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# --- Optional ---
# Set DEBUG_MODE=False and LOG_LEVEL=WARNING in production
DEBUG_MODE=True
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000

# --- Location (Patient home coordinates for zone classification) ---
BEWO_HOME_LAT=1.2931
BEWO_HOME_LON=103.8558
