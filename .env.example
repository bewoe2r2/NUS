# Bewo Healthcare Companion - Environment Configuration
# Copy this file to .env and fill in your keys
# Required: GEMINI_API_KEY (everything else has defaults)

# --- Required ---
# Google Gemini API Key (get from https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_api_key_here_starts_with_AIza

# --- SEA-LION (AI Singapore Official API — recommended) ---
# Sign up at https://playground.sea-lion.ai/ → API Key → Create New Trial API Key
SEALION_API_KEY=your_sealion_api_key

# --- SEA-LION (Cloudflare Workers AI — fallback) ---
# Get from: https://dash.cloudflare.com → Workers AI
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id
CLOUDFLARE_AUTH_TOKEN=your_cloudflare_api_token

# --- Security ---
# API key for all endpoints (set a strong key in production)
BEWO_API_KEY=bewo-dev-key-2026

# Allowed CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002

# --- Tool Providers (optional — uses mock providers by default) ---
# Appointment Booking: "mock" (demo) or "healthhub" (production FHIR R4)
APPOINTMENT_PROVIDER=mock
HEALTHHUB_API_URL=https://api.healthhub.sg/v1
HEALTHHUB_API_KEY=

# Caregiver Alerts: "mock" (demo) or "twilio" (production SMS/Voice)
ALERT_PROVIDER=mock
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# --- Optional (defaults shown) ---
DEBUG_MODE=True
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000
